{
  "name": "@openclaw/shared-utils",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.d.ts"
    },
    "./http": {
      "types": "./src/http.d.ts",
      "default": "./src/http.mjs"
    },
    "./persist": {
      "types": "./src/persist.d.ts",
      "default": "./src/persist.mjs"
    },
    "./work-view-trust": {
      "types": "./src/work-view-trust.d.ts",
      "default": "./src/work-view-trust.mjs"
    }
  },
  "scripts": {
    "build": "npm run typecheck && npm test",
    "typecheck": "tsc -p tsconfig.json --noEmit && node --check src/http.mjs && node --check src/persist.mjs && node --check src/work-view-trust.mjs",
    "test": "node --test test/*.test.mjs"
  }
}
